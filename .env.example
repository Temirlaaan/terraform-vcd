# =============================================================================
# Terraform VCD Dashboard — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Database (PostgreSQL) ---
DB_USER=tf_user
DB_PASSWORD=changeme
DB_NAME=terraform_dashboard
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- CORS (comma-separated list of allowed frontend origins) ---
CORS_ORIGINS=http://localhost:5173

# --- SSL verification for outgoing requests (VCD, Keycloak) ---
# Set to false only for development with self-signed certificates.
VERIFY_SSL=true

# --- Authentication ---
# Set to true to disable Keycloak auth entirely (for local testing only!)
AUTH_DISABLED=false
# Also set VITE_AUTH_DISABLED=true in your frontend env for full bypass.

# --- Keycloak SSO ---
KEYCLOAK_URL=https://sso-ttc.t-cloud.kz
KEYCLOAK_REALM=prod-v1
KEYCLOAK_CLIENT_ID=terraform-dashboard
KEYCLOAK_CLIENT_SECRET=

# --- Frontend Keycloak (same values, passed through Vite) ---
VITE_AUTH_DISABLED=false
VITE_KEYCLOAK_URL=https://sso-ttc.t-cloud.kz
VITE_KEYCLOAK_REALM=prod-v1
VITE_KEYCLOAK_CLIENT_ID=terraform-dashboard

# --- VMware Cloud Director (CloudAPI — dashboard metadata) ---
VCD_URL=https://vcd.example.com
VCD_API_TOKEN=
VCD_API_VERSION=38.0
VCD_ORG=System

# --- VCD Terraform provider credentials ---
VCD_USER=terraform-svc
VCD_PASSWORD=

# --- NSX-T (optional, for future use) ---
NSXT_URL=
NSXT_USER=
NSXT_PASSWORD=

# --- vSphere (optional, for future use) ---
VSPHERE_URL=
VSPHERE_USER=
VSPHERE_PASSWORD=

# --- Terraform ---
TERRAFORM_BINARY=/usr/local/bin/terraform
TF_STATE_BACKEND=pg
TF_WORKSPACE_BASE=/tmp/tf-workspaces
WORKSPACE_CLEANUP_ENABLED=true

# --- Telegram notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Frontend (used by docker-compose for the frontend container) ---
VITE_API_URL=http://localhost:8000
