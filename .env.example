# =============================================================================
# Terraform VCD Dashboard — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Database (PostgreSQL) ---
DB_USER=tf_user
DB_PASSWORD=changeme
DB_NAME=terraform_dashboard
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- CORS (comma-separated list of allowed frontend origins) ---
CORS_ORIGINS=http://localhost:5173

# --- SSL verification for outgoing requests (VCD, Keycloak) ---
# Set to false only for development with self-signed certificates.
VERIFY_SSL=true

# --- Keycloak SSO ---
KEYCLOAK_URL=https://sso.example.com
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=terraform-dashboard
KEYCLOAK_CLIENT_SECRET=

# --- VMware Cloud Director ---
VCD_URL=https://vcd.example.com/api
VCD_USER=terraform-svc
VCD_PASSWORD=
VCD_ORG=System

# --- NSX-T (optional, for future use) ---
NSXT_URL=
NSXT_USER=
NSXT_PASSWORD=

# --- vSphere (optional, for future use) ---
VSPHERE_URL=
VSPHERE_USER=
VSPHERE_PASSWORD=

# --- Terraform ---
TERRAFORM_BINARY=/usr/local/bin/terraform
TF_STATE_BACKEND=pg
TF_WORKSPACE_BASE=/tmp/tf-workspaces
WORKSPACE_CLEANUP_ENABLED=true

# --- Telegram notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Frontend (used by docker-compose for the frontend container) ---
VITE_API_URL=http://localhost:8000
