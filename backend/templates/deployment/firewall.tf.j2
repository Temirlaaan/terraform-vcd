{% if firewall_rules %}
resource "vcd_nsxt_firewall" "deployment" {
  org             = var.target_org
  edge_gateway_id = var.target_edge_id

{% for rule in firewall_rules %}
  rule {
    name        = "{{ rule.name | hcl_escape }}"
    direction   = "{{ rule.direction }}"
    ip_protocol = "{{ rule.ip_protocol }}"
    action      = "{{ rule.action }}"
    enabled     = {{ rule.enabled | lower }}
    logging     = {{ rule.logging | lower }}
{% if rule.source_slugs %}
    source_ids  = [{% for s in rule.source_slugs %}vcd_nsxt_ip_set.{{ s }}.id{% if not loop.last %}, {% endif %}{% endfor %}]
{% endif %}
{% if rule.destination_slugs %}
    destination_ids = [{% for s in rule.destination_slugs %}vcd_nsxt_ip_set.{{ s }}.id{% if not loop.last %}, {% endif %}{% endfor %}]
{% endif %}
{% if rule.app_port_profile_slugs %}
    app_port_profile_ids = [{% for s in rule.app_port_profile_slugs %}vcd_nsxt_app_port_profile.{{ s }}.id{% if not loop.last %}, {% endif %}{% endfor %}]
{% endif %}
  }

{% endfor %}
}
{% endif %}
